{
  "id": "memory-autodb",
  "config": {
    "embedding": {
      "apiKey": "${OPENAI_API_KEY}",
      "baseURL": "https://api.openai.com/v1",
      "model": "text-embedding-3-small"
    },

    // 数据库类型选择: "lancedb" (本地) 或 "supabase" (云端)
    "dbType": "lancedb",

    // LanceDB 本地存储配置 (仅 dbType=lancedb 时需要)
    "dbPath": "~/.openclaw/memory/autodb",

    // Supabase 云端存储配置 (可选，提供则开启混合模式或纯云端模式)
    "supabase": {
      "url": "${SUPABASE_URL}",
      "serviceKey": "${SUPABASE_SERVICE_KEY}"
    },

    // 自动捕获和召回
    "autoCapture": true,
    "autoRecall": true,
    "recallIncludeDocuments": false, // 自动召回是否包含扫描的文档数据
    "captureMaxChars": 500,

    // 批量处理配置 (可选)
    "batchProcessing": {
      "maxBatchSize": 20,
      "concurrency": 3,
      "retryAttempts": 3
    },

    // 目录扫描配置 (可选)
    "scanner": {
      "defaultIgnorePaths": [
        "node_modules",
        ".git",
        ".github",
        ".vscode",
        "dist",
        "build",
        "coverage"
      ],
      "customIgnoreRules": [
        "*.log",
        "*.tmp",
        "*.temp",
        "*.test.md",
        "*draft*"
      ]
    }
  }
}
